# MatchForge environment — copy to .env and fill in. NEVER commit the real .env.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://matchforge:CHANGEME@localhost:5432/matchforge_dev
POSTGRES_USER=matchforge
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=matchforge_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- App ---
APP_NAME=MatchForge
APP_ENV=development
APP_DOMAIN=match-forge.com
SECRET_KEY=CHANGEME
AUTH_PASSWORD=CHANGEME
APP_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# --- AI backends (local-first; cloud optional) ---
# Local LLM endpoint (Ollama default). Leave cloud keys blank to stay fully local.
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
EMBEDDING_MODEL=nomic-embed-text
VISION_MODEL=llava
TEXT_MODEL=llama3.2
# Optional cloud fallbacks (leave empty for privacy-first local-only operation)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Email (SMTP) — required for signup verification in production ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=MatchForge <noreply@match-forge.com>
SMTP_USE_TLS=true

# --- Connectors ---
# Per-connector credentials/exports live here once implemented. Respect each
# platform's Terms of Service and only ingest data you are authorized to access.
