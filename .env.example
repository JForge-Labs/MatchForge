# MatchForge environment — copy to .env and fill in. NEVER commit the real .env.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://matchforge:CHANGEME@localhost:5432/matchforge_dev
POSTGRES_USER=matchforge
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=matchforge_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- App ---
APP_NAME=MatchForge
APP_ENV=development
APP_DOMAIN=match-forge.com
SECRET_KEY=CHANGEME
AUTH_PASSWORD=CHANGEME
APP_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# --- Brave Search (optional — improves public social enrichment) ---
BRAVE_API_KEY=

# --- xAI Grok (required for vision + ranking + agentic X verification) ---
XAI_API_KEY=CHANGEME
XAI_VISION_MODEL=grok-4.3
XAI_TEXT_FAST=grok-4.20-0309-non-reasoning
XAI_TEXT_REASON=grok-4.20-0309-reasoning
# Server-side tool-loop depth for agentic runs (x_search/web_search)
XAI_AGENT_MAX_TURNS=8

# --- X API v2 (optional — official ground truth for X verification) ---
# Pay-per-use credits from the X Developer Console. Without a token,
# verification still works via Grok's x_search tool alone.
X_BEARER_TOKEN=
X_API_ENABLED=true
X_CACHE_TTL_HOURS=24
X_TIMELINE_MAX_POSTS=50

# --- Threat intel (trend-aware scoring from live X discussion) ---
THREAT_INTEL_ENABLED=true
THREAT_INTEL_REFRESH_DAYS=7

# Monetization (disable while iterating)
BILLING_ENABLED=false
SIGNUP_GRANT_TOKENS=100
SEED_MIN_TOKENS=0

# Capacity / surge traffic (foundational — flip on DO when taxed)
OVERLOAD_MODE=false
CAPACITY_MAX_CONCURRENT_UPLOADS=2
CAPACITY_RETRY_AFTER_SECONDS=120

# Stripe — one catalog Product; checkout uses dynamic price_data (min $10)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_ID=
TOKENS_PER_USD=20
MIN_TOPUP_USD=10
DEFAULT_TOPUP_USD=20

# Comma-separated operator emails for /admin dashboard
ADMIN_EMAILS=you@example.com

# --- Email (SMTP) — required for signup verification in production ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=MatchForge <noreply@match-forge.com>
SMTP_USE_TLS=true

# --- Connectors ---
# Per-connector credentials/exports live here once implemented. Respect each
# platform's Terms of Service and only ingest data you are authorized to access.